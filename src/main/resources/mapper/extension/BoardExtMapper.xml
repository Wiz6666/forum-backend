<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weisizhang.forumbackend.dao.BoardMapper">


    <!-- 查询前N条有效的板块记录 -->
    <select id="selectByNum" resultMap="BaseResultMap" parameterType="java.lang.Integer">
        select
        <include refid="Base_Column_List" />
        from t_board
        where deleteState=0 and state = 0
        order by sort asc limit 0, #{num,jdbcType=INTEGER}
    </select>

</mapper>